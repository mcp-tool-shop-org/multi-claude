{
  "name": "@multi-claude/cli",
  "version": "0.1.0",
  "description": "Multi-Claude — lane-based parallel build system",
  "type": "module",
  "bin": {
    "multi-claude": "./dist/bin/multi-claude.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
