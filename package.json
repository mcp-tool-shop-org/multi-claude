{
  "name": "@mcptoolshop/multi-claude",
  "version": "1.0.0",
  "description": "Multi-Claude — lane-based parallel build system for Claude Code",
  "type": "module",
  "bin": {
    "multi-claude": "./dist/bin/multi-claude.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ test/",
    "verify": "npm run typecheck && npm run test && npm run build",
    "multi-claude": "tsx bin/multi-claude.ts"
  },
  "keywords": [
    "multi-claude",
    "build-system",
    "parallel"
  ],
  "author": "mcp-tool-shop",
  "license": "MIT",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.79",
    "better-sqlite3": "^11.7.0",
    "commander": "^13.0.0",
    "express": "^5.2.1"
  },
  "engines": {
    "node": ">=20"
  }
}
