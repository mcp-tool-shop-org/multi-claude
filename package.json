    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.79",
    "better-sqlite3": "^11.7.0",
    "commander": "^13.0.0"
  },
  "engines": {
    "node": ">=20"
